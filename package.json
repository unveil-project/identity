    "bumpp": "^11.0.1",
    "dayjs": "^1.11.20",
    "publint": "^0.3.18",
    "typescript": "^6.0.2",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  },
  "packageManager": "pnpm@10.33.0"
