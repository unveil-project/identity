{
  "name": "@unveil/identity",
  "version": "1.0.0",
  "type": "module",
  "description": "Identify automation patterns in GitHub accounts through behavioral analysis",
  "homepage": "https://github.com/unveil-project/identity#readme",
  "bugs": {
    "url": "https://github.com/unveil-project/identity/issues"
  },
  "license": "MIT",
  "author": "Matteo Gabriele <m.gabriele.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unveil-project/identity.git"
  },
  "workspaces": [
    "."
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./ai": "./dist/ai/index.mjs",
    "./ai-interpret": "./dist/ai-interpret/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "add:fixture": "node scripts/fetch-github-events.js",
    "ai:analyse": "npx jiti scripts/ai-analyser-user.ts",
    "prepublishOnly": "vitest --run && pnpm run build"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@octokit/types": "^16.0.0",
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "dayjs": "^1.11.20",
    "publint": "^0.3.17",
    "tsdown": "^0.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "voight-kampff-compactor": "^1.0.0",
    "zod": "^4.3.6"
  }
}
