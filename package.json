{
  "name": "@unveil/identity",
  "version": "1.3.0",
  "type": "module",
  "description": "Identify automation patterns in GitHub accounts through behavioral analysis",
  "homepage": "https://github.com/unveil-project/identity#readme",
  "bugs": {
    "url": "https://github.com/unveil-project/identity/issues"
  },
  "license": "MIT",
  "author": "Matteo Gabriele <m.gabriele.dev@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unveil-project/identity.git"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "add:fixture": "node scripts/fetch-github-events.js",
    "update-fixtures": "tsx scripts/fetch-regression-fixtures.ts",
    "playground": "pnpm -F @unveil/identity-playground dev",
    "regression-test": "tsx scripts/regression-test.ts",
    "regression-analyze": "tsx benchmark/analyze-reports.ts",
    "regression-analyze:full": "tsx benchmark/analyze-reports.ts --full",
    "prepublishOnly": "vitest --run && tsx scripts/regression-test.ts && pnpm run build"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@octokit/types": "^16.0.0",
    "@types/node": "^25.0.3",
    "bumpp": "^10.3.2",
    "changelogithub": "^14.0.0",
    "dayjs": "^1.11.20",
    "publint": "^0.3.17",
    "tsdown": "^0.18.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
